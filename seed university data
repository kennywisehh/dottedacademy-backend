class Command(BaseCommand):
    help = 'Seed Nigerian universities, faculties, and departments from NUC data'

    def add_arguments(self, parser):
        parser.add_argument(
            '--clear',
            action='store_true',
            help='Clear existing university data before seeding',
        )

    def handle(self, *args, **options):
        if options['clear']:
            self.stdout.write('Clearing existing data...')
            Department.objects.all().delete()
            Faculty.objects.all().delete()
            University.objects.all().delete()
            self.stdout.write(self.style.WARNING('Existing data cleared.'))

        uni_count = 0
        fac_count = 0
        dep_count = 0

        for uni_data in UNIVERSITIES_DATA:
            university, created = University.objects.get_or_create(
                name=uni_data['name'],
                defaults={
                    'abbreviation': uni_data['abbreviation'],
                    'is_active': True,
                }
            )

            if created:
                uni_count += 1
                self.stdout.write(f'  Created university: {university.name}')
            else:
                self.stdout.write(f'  Skipped (exists): {university.name}')

            for fac_data in uni_data['faculties']:
                faculty, fac_created = Faculty.objects.get_or_create(
                    university=university,
                    name=fac_data['name'],
                    defaults={'is_active': True}
                )
                if fac_created:
                    fac_count += 1

                for dept_name in fac_data['departments']:
                    dept, dept_created = Department.objects.get_or_create(
                        faculty=faculty,
                        name=dept_name,
                        defaults={'is_active': True}
                    )
                    if dept_created:
                        dep_count += 1

        self.stdout.write(self.style.SUCCESS(
            f'\nDone! Created {uni_count} universities, {fac_count} faculties, {dep_count} departments.'
        ))